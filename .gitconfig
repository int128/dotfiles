[merge]
  ff = false
[pull]
  rebase = true
[push]
  default = tracking
[alias]
  ci = commit
  co = checkout
  com = checkout origin/HEAD
  cob = checkout -B
  ls = log --graph --decorate --oneline
  ll = log --graph --decorate --stat --pretty=fuller
  s = status --short --branch
  po = push origin
  rom = rebase origin/HEAD
  fo = fetch origin --prune
  fom = "!git fo && git com"
